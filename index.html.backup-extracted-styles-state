    <!-- ============================================================



         INTERACTIVE GLASS MODAL: HIGH-VALUE TOUCHPOINT LOGGING



         ============================================================ -->



    <div class="dashboard-modal-overlay" id="quick-log-modal">



        <div class="dashboard-modal-card">



            <div class="modal-header">



                <h3>Log New Relationship Touchpoint</h3>



                <button class="btn-close-modal" id="btn-close-log-modal" aria-label="Close modal">×</button>



            </div>



            <div class="modal-body">



                <p class="modal-intro-copy">Log your B2B touchpoints. Low-value automated template actions will log in history, but only **High-Value manual engagements** will reset relationship aging timers.</p>



                



                <form class="modal-form" onsubmit="return false;">



                    <div class="form-group">



                        <label for="select-client">Target Relationship / Client</label>



                        <select id="select-client" class="form-select">



                            <option value="Chevron Logistics">Chevron Logistics (Red Alert)</option>



                            <option value="Apex Global Retail">Apex Global Retail (Orange Alert)</option>



                            <option value="Vanguard Health">Vanguard Health (Extended Inactivity)</option>



                        </select>



                    </div>



                    <div class="form-group">



                        <label for="select-activity-type">Engagement Type</label>



                        <select id="select-activity-type" class="form-select">



                            <option value="call" selected>1-on-1 Phone Call (High-Value)</option>



                            <option value="meeting">Video or In-Person Meeting (High-Value)</option>



                            <option value="personal-email">Personal Hand-Written Email (High-Value)</option>



                            <option value="gift">Physical Gifting Box Dispatch (High-Value)</option>



                            <option value="bulk-drip">Automated Newsletter Drip Campaign (Low-Value)</option>



                            <option value="generic-template">System Template Auto-Outreach (Low-Value)</option>



                        </select>



                    </div>



                    



                    <!-- DYNAMIC TIMER RESET INDICATOR (Feedback box) -->



                    <div class="activity-timer-feedback-box" id="timer-feedback-indicator">



                        <span class="feedback-icon positive">✓</span>



                        <div class="feedback-text">



                            <strong class="feedback-title">High-Value Engagement Validated</strong>



                            <span class="feedback-desc">Resets the client's inactivity decay timer to Green (Active).</span>



                        </div>



                    </div>







                    <div class="form-group">



                        <label for="input-notes">Meeting Notes & Summary</label>



                        <textarea id="input-notes" class="form-textarea" placeholder="Document the core summary, key items mentioned, or feedback received during this touchpoint..."></textarea>



                    </div>



                    



                    <!-- Modal Interaction Grading System Group -->



                    <div class="form-group inline-style-19">



                        <label class="uploader-label-micro">Interaction Grade</label>



                        <div class="grade-selector-group" id="modal-grade-selector">



                            <button type="button" class="grade-btn grade-btn-a" data-grade="A" title="Very Good (Receptive, understanding, positive)">A</button>



                            <button type="button" class="grade-btn grade-btn-c active" data-grade="C" title="Okay (Neutral, some friction/bad news but neutral outcome)">C</button>



                            <button type="button" class="grade-btn grade-btn-f" data-grade="F" title="Very Bad (Hostile, complaint, 'don't talk')">F</button>



                        </div>



                        <div class="grade-feedback-desc" id="modal-grade-feedback-desc">Grade C: Okay / Neutral Interaction</div>



                        <input type="hidden" id="modal-selected-grade" value="C">



                    </div>



                    



                    <div class="modal-form-actions">



                        <button type="submit" class="btn-submit-log" id="btn-submit-activity">Submit Engagement</button>



                        <button type="button" class="btn-cancel-log" id="btn-cancel-log-modal">Cancel</button>



                    </div>



                </form>



            </div>



        </div>



