    <!-- Runtime style polyfill for extracted inline styles -->
    <script>
      (function() {
        document.addEventListener('DOMContentLoaded', () => {
          const elements = document.querySelectorAll('[class*="inline-style-"]');
          elements.forEach(el => {
            const computed = window.getComputedStyle(el);
            const className = typeof el.className === 'string' ? el.className : el.getAttribute('class') || '';
            const classes = className.split(/\s+/);
            const hasInlineStyleClass = classes.some(c => c.startsWith('inline-style-'));
            if (hasInlineStyleClass) {
              const elDisplay = computed.display;
              if (elDisplay === 'none' || elDisplay === 'flex' || elDisplay === 'grid') {
                el.style.display = elDisplay;
              }
              if (computed.opacity !== '1') {
                el.style.opacity = computed.opacity;
              }
              if (computed.visibility === 'hidden') {
                el.style.visibility = 'hidden';
              }
            }
          });
        });
      })();
